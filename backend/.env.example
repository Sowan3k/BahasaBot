# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-this-to-a-64-character-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── Database ───────────────────────────────────────────────────────────────────
# Async engine (used by FastAPI at runtime)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bahasabot
# Sync engine (used only by Alembic migrations)
SYNC_DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/bahasabot

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here.apps.googleusercontent.com

# ── Google Gemini ──────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash             # used for course/quiz generation
CHATBOT_GEMINI_MODEL=gemini-2.5-flash     # used for chatbot streaming
EMBEDDING_MODEL=models/gemini-embedding-001

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Monitoring ─────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
CHATBOT_RATE_LIMIT_PER_MINUTE=20

# ── Admin ───────────────────────────────────────────────────────────────────────
# Email address that automatically receives role='admin' on first registration.
# Leave blank to disable automatic admin seeding.
ADMIN_EMAIL=admin@example.com

# ── Email (Resend) ──────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=BahasaBot <noreply@yourdomain.com>

# ── Image Generation ────────────────────────────────────────────────────────────
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview


