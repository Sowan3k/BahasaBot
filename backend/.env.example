# ── App ────────────────────────────────────────────────────────────────────────
# Runtime environment: 'development' or 'production'
# Production disables /docs and /redoc Swagger UI endpoints
APP_ENV=development

# ── Security ───────────────────────────────────────────────────────────────────
# 64-character random string used to sign JWT tokens
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-64-character-random-string

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── Database ───────────────────────────────────────────────────────────────────
# Async engine — used by FastAPI at runtime (asyncpg driver)
# Neon: postgresql+asyncpg://user:pass@ep-xxx.neon.tech/dbname?ssl=require
# Local: postgresql+asyncpg://postgres:password@localhost:5432/bahasabot
# NOTE: omit 'channel_binding=require' — asyncpg does not support it
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/bahasabot

# Sync engine — used ONLY by Alembic migrations (psycopg2 driver)
# Neon: postgresql+psycopg2://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
SYNC_DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/bahasabot

# ── Redis ──────────────────────────────────────────────────────────────────────
# Redis Cloud or Railway Redis addon URL
# Local: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Google OAuth ───────────────────────────────────────────────────────────────
# OAuth 2.0 Client ID from Google Cloud Console
# Used to verify Google ID tokens sent from the frontend sign-in button
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── Google Gemini ──────────────────────────────────────────────────────────────
# API key from Google AI Studio (aistudio.google.com)
GOOGLE_API_KEY=your-google-gemini-api-key-here

# Model for course/quiz generation and adaptive quiz
GEMINI_MODEL=gemini-2.5-flash

# Model for chatbot SSE streaming responses
CHATBOT_GEMINI_MODEL=gemini-2.5-flash

# Embedding model for RAG pgvector indexing
EMBEDDING_MODEL=models/gemini-embedding-001

# Image generation model — for journey banners, milestone cards, course covers
# WARNING: Do NOT change — pinned to the current production model
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Development: http://localhost:3000
# Production:  https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend URL ───────────────────────────────────────────────────────────────
# Used by email_service.py to build password-reset links in outgoing emails
# Must match the deployed frontend URL exactly (no trailing slash)
FRONTEND_URL=http://localhost:3000

# ── Admin ───────────────────────────────────────────────────────────────────────
# Email that automatically receives role='admin' on first registration
# Leave blank to disable automatic admin role assignment
ADMIN_EMAIL=admin@example.com

# ── Email (Resend) ──────────────────────────────────────────────────────────────
# API key from resend.com — used for forgot-password reset emails
RESEND_API_KEY=re_your_resend_api_key_here

# Sender shown in password reset emails (must be a verified domain on Resend)
RESEND_FROM_EMAIL=BahasaBot <noreply@yourdomain.com>

# ── Monitoring (Sentry) ────────────────────────────────────────────────────────
# DSN from sentry.io — leave blank to disable error reporting
SENTRY_DSN=

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
CHATBOT_RATE_LIMIT_PER_MINUTE=20
