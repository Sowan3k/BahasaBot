# .dockerignore for backend/ build context (Render / Railway with root dir = backend/)
# This file must live in backend/ to be picked up when build context = backend/.

# ── Secrets — NEVER include in image ──────────────────────────────────────────
.env
.env.*

# ── Python runtime artifacts ───────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# ── OS / IDE ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
