# .dockerignore — applies to the Docker build context (project root)
# This file controls what gets sent to the Docker daemon.
# Keep it in sync with .gitignore; exclude everything not needed at runtime.

# ── Environment secrets — NEVER in image ──────────────────────────────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local
**/.env
**/.env.local

# ── Python runtime artifacts ───────────────────────────────────────────────────
**/__pycache__/
**/*.py[cod]
**/*.pyo
backend/venv/
backend/.venv/
**/*.egg-info/
**/*.egg
**/.pytest_cache/
**/.mypy_cache/
**/.coverage
**/htmlcov/
**/dist/
**/build/

# ── Node / Next.js ─────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
**/npm-debug.log*
**/yarn-error.log*
**/yarn-debug.log*

# ── Git ────────────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── OS / IDE ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
**/*.swp
**/*.swo

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/

# ── Docs / dev files (not needed at runtime) ──────────────────────────────────
*.md
DEPLOYMENT.md
database/
docs/

# ── Test files ────────────────────────────────────────────────────────────────
**/tests/
**/*.test.py
**/*.spec.py

# ── TypeScript build cache ─────────────────────────────────────────────────────
frontend/tsconfig.tsbuildinfo

# ── Local dev scripts ─────────────────────────────────────────────────────────
*.bat
*.sh
start-bahasabot*
