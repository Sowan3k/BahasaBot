# ── NextAuth ───────────────────────────────────────────────────────────────────
# Full public URL of this frontend (no trailing slash)
# Development: http://localhost:3000
# Production:  https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# 32+ character random string — signs the NextAuth session cookie
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-this-to-a-32-character-random-string

# ── Backend API ────────────────────────────────────────────────────────────────
# FastAPI backend URL (no trailing slash)
# Development: http://localhost:8000
# Production:  https://your-railway-backend.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Same OAuth 2.0 Client ID used by the backend — shown on the Google sign-in button
# Must match GOOGLE_CLIENT_ID in backend/.env exactly
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── App metadata ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=BahasaBot

# ── Monitoring (Sentry) ────────────────────────────────────────────────────────
# Public DSN — safe to expose in the browser bundle (Sentry designed it this way)
# Leave blank to disable client-side error reporting
NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token — used ONLY at build time to upload source maps (not at runtime)
# Create at: sentry.io → Settings → Auth Tokens
# Required for SENTRY_AUTH_TOKEN in CI/CD or Vercel build env
SENTRY_AUTH_TOKEN=
